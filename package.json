{
  "name": "nonverbal-reasoning-games",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based mini-games for training nonverbal visual-spatial reasoning.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pages": "NEXT_PUBLIC_BASE_PATH=/nonverbal-reasoning-games next build",
    "start": "next start",
    "test": "node --test tests/*.test.mjs",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build:pages && npm test"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "typescript": "5.9.3"
  },
  "type": "module"
}
